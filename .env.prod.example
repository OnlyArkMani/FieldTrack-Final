# FieldTrack — PRODUCTION environment template.
# Copy to `.env.prod` on the VPS (NOT in git), fill in real values.
# Generate secrets with:  openssl rand -hex 32

# ── App ──────────────────────────────────────────────────────────
APP_ENV=production
APP_NAME=FieldTrack
DEBUG=false                        # MUST be false — disables /docs and /openapi.json
API_V1_PREFIX=/api/v1
# Comma-separated. Must match the domain(s) the admin SPA is served from.
ALLOWED_ORIGINS=https://your-domain.com

# ── Database (Postgres 15 + PostGIS) ────────────────────────────
POSTGRES_USER=fieldtrack
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=fieldtrack
# DATABASE_URL is built by docker-compose.prod.yml from the three vars above;
# you don't need to set it here for the app container. Only set it if you run
# alembic from the host (not recommended in prod — use `docker compose exec app`).
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ── Redis ────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password
# REDIS_URL is built by docker-compose.prod.yml from REDIS_PASSWORD.

# ── JWT ──────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_openssl_rand_hex_32_different
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Firebase Cloud Messaging ─────────────────────────────────────
FCM_SERVICE_ACCOUNT_FILE=/run/secrets/fcm-service-account.json
FCM_PROJECT_ID=your-firebase-project-id

# ── Rate limiting ────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120

# ── Reports (CSV/Excel/PDF exports) ──────────────────────────────
REPORT_STORAGE_DIR=/srv/fieldtrack/reports
REPORT_RETENTION_MINUTES=60

# ── App server ───────────────────────────────────────────────────
# Number of Gunicorn workers (docker-compose.prod.yml command). 4 is the
# default for a 2 vCPU VPS — change here, nothing else, to scale up.
GUNICORN_WORKERS=4

# ── Monitoring (monitoring/docker-compose.monitoring.yml) ────────
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_admin_password

# ── Image tag ────────────────────────────────────────────────────
# Which built image the `app` service runs. The deploy workflow sets this to
# the commit SHA; locally it defaults to "latest".
IMAGE_TAG=latest
