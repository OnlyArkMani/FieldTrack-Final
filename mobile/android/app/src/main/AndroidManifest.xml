<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- ═══════════ Location permissions ═══════════
         FINE + COARSE: standard GPS.
         BACKGROUND_LOCATION (API 29+): the "Allow all the time" grant —
           without it the foreground service gets NO fixes when the app is
           backgrounded on Android 10+.
         Request order in-app (PermissionHelperService): fine first, then
         background — Android refuses to show "all the time" otherwise. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- ═══════════ Foreground service (Android 8+ requirement) ═══════════
         FOREGROUND_SERVICE_LOCATION is mandatory on API 34+ (Android 14):
         a location-type foreground service crashes at start without it. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- Restart tracking after device reboot (background_locator_2's boot
         receiver re-launches the service if it was running). -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Battery optimization exemption prompt (Samsung/stock killer). -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Networking + connectivity checks + wakelock for the locator cycles. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Android 13+ (API 33): notifications are opt-in and require a runtime
         grant. Requested in-app by FcmService with a rationale first. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Needed by android_intent_plus to resolve OEM settings activities
         (MIUI security center etc.) on Android 11+ package visibility. -->
    <queries>
        <package android:name="com.miui.securitycenter" />
        <package android:name="com.coloros.safecenter" />
        <package android:name="com.oppo.safe" />
        <package android:name="com.vivo.permissionmanager" />
        <package android:name="com.oneplus.security" />
    </queries>

    <application
        android:label="FieldTrack"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:enableOnBackInvokedCallback="true"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:networkSecurityConfig="@xml/network_security_config">
        <!-- allowBackup=false: blocks ADB/cloud backup extraction of the local
             SQLite attendance/location cache and stored JWT (security).
             networkSecurityConfig: HTTPS-only in release (no cleartext); the
             debug build (src/debug) relaxes this for local dev servers. -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ═══════════ background_locator_2 components ═══════════
             The foreground service that owns the persistent notification
             ("FieldTrack is tracking your location") and the Dart isolate. -->
        <service
            android:name="yukams.app.background_locator_2.IsolateHolderService"
            android:foregroundServiceType="location"
            android:exported="false"
            android:permission="android.permission.FOREGROUND_SERVICE" />

        <!-- Restarts the service after reboot if tracking was active. -->
        <receiver
            android:name="yukams.app.background_locator_2.BootBroadcastReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- ═══════════ FCM defaults ═══════════
             Channel that backgrounded/system-drawn pushes route to (must match
             FcmService._channelId). Icon + colour for the status-bar glyph. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="fieldtrack_push" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@mipmap/ic_launcher" />

        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
</manifest>
