# Admin web — Vite environment. Copy to `.env` and adjust.

# API prefix the SPA calls (the dev proxy in vite.config.js forwards /api to
# VITE_PROXY_TARGET). Leave as-is unless your backend mounts elsewhere.
VITE_API_PREFIX=/api/v1

# Where the dev proxy forwards /api during `npm run dev`. This is the published
# nginx port (app:8000 is internal-only); nginx handles the /api/v1/ws upgrade.
VITE_PROXY_TARGET=http://localhost:8090

# WebSocket URL for the live admin feed. Leave blank to derive from the page
# origin (recommended; works with the dev proxy and behind Nginx).
VITE_WS_URL=
