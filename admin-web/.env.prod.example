# FieldTrack admin-web — PRODUCTION env template.
# scripts/build_admin.sh copies this -> admin-web/.env.production before
# running `npm run build` (Vite automatically loads .env.production for
# production builds).

VITE_API_PREFIX=/api/v1
# Leave blank — same-origin behind Nginx, derived from the page origin.
VITE_WS_URL=
